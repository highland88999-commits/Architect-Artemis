{
  "version": 2,
  "builds": [
    {
      "src": "gemini_bridge.py",
      "use": "@vercel/python"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build"
    }
  ],
  "rewrites": [
    { "source": "/api/transmit", "destination": "/gemini_bridge.py" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "cleanUrls": true
}
