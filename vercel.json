{
  "version": 2,
  "crons": [
    {
      "path": "/api/cron/batch-cycle",
      "schedule": "0 * * * *" 
    },
    {
      "path": "/api/cron/daily-summary",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/metabolism-pulse",
      "schedule": "0 0 1 * *"
    }
  ],
  "rewrites": [
    { 
      "source": "/api/chat", 
      "destination": "/api/transmit" 
    },
    { 
      "source": "/((?!api/).*)", 
      "destination": "/index.html" 
    }
  ],
  "cleanUrls": true
}
