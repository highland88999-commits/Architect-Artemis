    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "concurrently": "^8.2.2",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "lucide-react": "^0.460.0",
    "next": "14.2.3",
    "next-themes": "^0.4.3",
    "node-fetch": "^2.6.7",
    "pg": "^8.11.5",
    "python-shell": "^5.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^3.2.0",
    "sonner": "^1.5.0",
    "tailwind-merge": "^2.5.4"
