{
  "name": "architect-artemis-ecosystem",
  "version": "1.0.0",
  "description": "Artemis Symbiote — Universal Architect & Stewardship Engine",
  "type": "module",
  "main": "engine/server.js",
  "scripts": {
    "dev:ui": "next dev -p 3000",
    "dev:engine": "node engine/server.js",
    "dev": "concurrently \"npm run dev:ui\" \"npm run dev:engine\"",
