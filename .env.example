# .env.example - ARTEMIS Environment Variables Template
# Copy this to .env and fill in your real values
# NEVER commit .env to GitHub!

# Required for Gemini (core/architect.js, symbiote.py)
GEMINI_API_KEY=your-google-ai-studio-key-here

# Required for Clarifai (core/consensus.js)
CLARIFAI_PAT=your-clarifai-personal-access-token-here

# Required for landline/heartbeat gating (index.html, workflows)
ARTEMIS_LANDLINE=CONNECTED

# Optional: Vercel / deployment-specific
VERCEL_URL=https://architect-artemis.vercel.app

# Optional: GitHub token for catalogToGitHub (if using old crawler.js)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Database (if using PostgreSQL or other external DB)
DATABASE_URL=postgres://user:pass@host:port/dbname

# Optional: Rate limiting / API keys for future expansions
# RATE_LIMIT_PER_HOUR=20
